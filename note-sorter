#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["anthropic"]
# requires-python = ">=3.12"
# ///
"""Obsidian Note Sorter — watches ~/obsidian-drop/ and files notes into the vault."""

import datetime
import hashlib
import json
import logging
import os
import re
import shutil
import sys
import time
import urllib.request
import urllib.error
from logging.handlers import RotatingFileHandler
from pathlib import Path

import anthropic

# ---------------------------------------------------------------------------
# Defaults (overridden by config.json)
# ---------------------------------------------------------------------------
DEFAULTS = {
    "vault_path": "",
    "drop_dir": "~/obsidian-drop",
    "filed_dir": "~/obsidian-drop/Filed",
    "config_dir": "~/.config/note-sorter",
    "model": "claude-sonnet-4-20250514",
    "max_output_tokens": 1024,
    "api_key_env": "ANTHROPIC_API_KEY",
    "connectivity_timeout_seconds": 5,
    "file_settle_seconds": 5,
    "log_level": "INFO",
    "excluded_dirs": [".trash", ".obsidian", "templates", ".space"],
    "dry_run": False,
}

SYSTEM_PROMPT = """\
You are a personal knowledge management assistant. You help file notes into an \
Obsidian vault organized using the PARA method (Projects, Areas, Resources, Archive).

You will receive:
1. The user's filing preferences (how they like things organized)
2. An index of all existing notes in the vault (name and folder path)
3. A new note to be filed

Your job is to analyze the note and return a JSON decision with these fields:
- "action": either "new" (create as a new note) or "append" (add to an existing note)
- "reasoning": 1-2 sentences explaining your decision
- "folder": the destination folder path relative to vault root (for "new" action only)
- "filename": the filename to use WITHOUT .md extension (for "new" action only)
- "target_note": the exact name of the existing note to append to (for "append" action only)
- "wikilinks": array of existing note names that are semantically related to this content
- "suggested_tags": array of tags to add to frontmatter (use the vault's existing tag style)

Rules:
- Only suggest "append" if the new content is clearly a continuation or addition to a \
specific existing note. When in doubt, create a new note.
- For the folder, use existing folder paths from the vault index. Do not invent new folders.
- For wikilinks, only suggest notes that actually exist in the index. Focus on semantic \
relevance, not just keyword matching.
- Limit wikilinks to the 5-8 most relevant. Do not over-link.
- Return ONLY valid JSON. No markdown code fences. No commentary outside the JSON.\
"""


# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
def load_config() -> dict:
    """Load config.json and merge with defaults."""
    config_path = Path("~/.config/note-sorter/config.json").expanduser()
    cfg = dict(DEFAULTS)
    if config_path.exists():
        with open(config_path) as f:
            user_cfg = json.load(f)
        cfg.update(user_cfg)
    # Expand ~ in all path values
    for key in ("vault_path", "drop_dir", "filed_dir", "config_dir"):
        cfg[key] = str(Path(cfg[key]).expanduser()) if cfg[key] else ""
    return cfg


def load_env_file(config_dir: str) -> None:
    """Load .env file as a fallback for environment variables."""
    env_path = Path(config_dir) / ".env"
    if not env_path.exists():
        return
    with open(env_path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, _, value = line.partition("=")
            key, value = key.strip(), value.strip().strip("'\"")
            if key and key not in os.environ:
                os.environ[key] = value


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
def setup_logging(config: dict) -> logging.Logger:
    """Configure rotating file + stderr logging."""
    logger = logging.getLogger("note-sorter")
    logger.setLevel(getattr(logging, config["log_level"].upper(), logging.INFO))

    fmt = logging.Formatter("%(asctime)s %(levelname)-5s %(message)s",
                            datefmt="%Y-%m-%d %H:%M:%S")

    log_path = Path(config["config_dir"]) / "note-sorter.log"
    log_path.parent.mkdir(parents=True, exist_ok=True)
    fh = RotatingFileHandler(log_path, maxBytes=1_000_000, backupCount=3)
    fh.setFormatter(fmt)
    logger.addHandler(fh)

    sh = logging.StreamHandler(sys.stderr)
    sh.setFormatter(fmt)
    logger.addHandler(sh)

    return logger


# ---------------------------------------------------------------------------
# Connectivity
# ---------------------------------------------------------------------------
def check_connectivity(timeout: int) -> bool:
    """Return True if the Anthropic API is reachable."""
    try:
        req = urllib.request.Request("https://api.anthropic.com", method="HEAD")
        urllib.request.urlopen(req, timeout=timeout)
        return True
    except urllib.error.HTTPError:
        # Any HTTP response (even 404) means we're online
        return True
    except (urllib.error.URLError, OSError, TimeoutError):
        return False


# ---------------------------------------------------------------------------
# Vault index
# ---------------------------------------------------------------------------
def build_vault_index(vault_path: str, cache_path: Path,
                      excluded_dirs: list[str],
                      logger: logging.Logger) -> list[dict]:
    """Walk vault for .md files, cache with hash comparison."""
    vault = Path(vault_path)
    notes: list[dict] = []
    excluded = set(excluded_dirs)

    for md_file in sorted(vault.rglob("*.md")):
        # Skip excluded directories
        parts = md_file.relative_to(vault).parts
        if any(p.startswith(".") or p in excluded for p in parts[:-1]):
            continue
        rel_path = str(md_file.relative_to(vault))
        name = md_file.stem
        notes.append({"name": name, "path": rel_path})

    # Hash comparison for caching
    notes_str = json.dumps(notes, sort_keys=True)
    current_hash = hashlib.sha256(notes_str.encode()).hexdigest()

    if cache_path.exists():
        try:
            with open(cache_path) as f:
                cached = json.load(f)
            if cached.get("hash") == current_hash:
                logger.debug("Vault index unchanged (%d notes)", len(notes))
                return cached["notes"]
        except (json.JSONDecodeError, KeyError):
            pass

    # Write new cache
    cache_data = {
        "hash": current_hash,
        "updated": datetime.datetime.now().isoformat(),
        "notes": notes,
    }
    cache_path.parent.mkdir(parents=True, exist_ok=True)
    with open(cache_path, "w") as f:
        json.dump(cache_data, f, indent=2)
    logger.info("Vault index rebuilt: %d notes", len(notes))
    return notes


def format_index_for_prompt(notes: list[dict]) -> str:
    """Format the vault index as a compact list for the Claude prompt."""
    lines = [f"{n['name']} | {n['path']}" for n in notes]
    return "\n".join(lines)


# ---------------------------------------------------------------------------
# Filing prompt
# ---------------------------------------------------------------------------
def load_filing_prompt(config_dir: str) -> str:
    """Read the user's filing preferences."""
    path = Path(config_dir) / "filing-prompt.md"
    if not path.exists():
        return "(No filing preferences configured.)"
    return path.read_text()


# ---------------------------------------------------------------------------
# Drop folder scanning
# ---------------------------------------------------------------------------
def get_drop_files(drop_dir: str, filed_dir: str,
                   settle_seconds: int) -> list[Path]:
    """List .md files in drop folder, skipping Filed/ and recently modified files."""
    drop = Path(drop_dir)
    filed = Path(filed_dir)
    if not drop.exists():
        return []

    now = time.time()
    files: list[Path] = []
    for f in sorted(drop.glob("*.md"), key=lambda p: p.stat().st_mtime):
        if f.parent == filed:
            continue
        # Skip files still being written
        if now - f.stat().st_mtime < settle_seconds:
            continue
        files.append(f)
    return files


# ---------------------------------------------------------------------------
# Claude API interaction
# ---------------------------------------------------------------------------
def analyze_note(client: anthropic.Anthropic, note_content: str,
                 note_filename: str, vault_index_text: str,
                 filing_prompt: str, model: str,
                 max_tokens: int, logger: logging.Logger) -> dict:
    """Call Claude to analyze a note and return a filing decision."""
    user_message = (
        f"## My Filing Preferences\n\n{filing_prompt}\n\n"
        f"## Vault Index\n\n{vault_index_text}\n\n"
        f"## Note to File\n\nFilename: {note_filename}\n\n{note_content}"
    )

    logger.debug("Sending to Claude: %d chars", len(user_message))

    for attempt in range(2):
        try:
            response = client.messages.create(
                model=model,
                max_tokens=max_tokens,
                system=SYSTEM_PROMPT,
                messages=[{"role": "user", "content": user_message}],
            )
            text = response.content[0].text.strip()
            return parse_claude_response(text)

        except anthropic.RateLimitError:
            if attempt == 0:
                logger.warning("Rate limited, waiting 60s before retry")
                time.sleep(60)
            else:
                raise
        except anthropic.APIError as e:
            if attempt == 0:
                logger.warning("API error (%s), retrying in 5s", e)
                time.sleep(5)
            else:
                raise

    return {}  # unreachable, but satisfies type checker


def parse_claude_response(text: str) -> dict:
    """Parse Claude's JSON response, stripping accidental markdown fences."""
    text = text.strip()
    if text.startswith("```"):
        text = re.sub(r"^```(?:json)?\s*", "", text)
        text = re.sub(r"\s*```$", "", text)
    return json.loads(text)


# ---------------------------------------------------------------------------
# Decision validation
# ---------------------------------------------------------------------------
def validate_decision(decision: dict, vault_path: str,
                      notes: list[dict],
                      logger: logging.Logger) -> dict:
    """Validate and sanitize Claude's filing decision."""
    vault = Path(vault_path)
    note_names = {n["name"] for n in notes}
    note_paths = {n["name"]: n["path"] for n in notes}

    action = decision.get("action", "new")
    if action not in ("new", "append"):
        logger.warning("Invalid action '%s', defaulting to 'new'", action)
        action = "new"

    if action == "append":
        target = decision.get("target_note", "")
        if target not in note_names:
            logger.warning("Append target '%s' not found, switching to 'new'", target)
            action = "new"
        else:
            decision["target_path"] = note_paths[target]

    if action == "new":
        folder = decision.get("folder", "Inbox")
        dest = vault / folder
        if not dest.exists():
            logger.warning("Folder '%s' does not exist, falling back to Inbox", folder)
            decision["folder"] = "Inbox"
            dest = vault / "Inbox"
            dest.mkdir(exist_ok=True)

        filename = decision.get("filename", "Untitled")
        # Sanitize filename
        filename = re.sub(r'[<>:"/\\|?*]', "", filename).strip()
        if not filename:
            filename = "Untitled"
        decision["filename"] = filename

    decision["action"] = action

    # Validate wikilinks — only keep ones that exist
    raw_links = decision.get("wikilinks", [])
    valid_links = [lnk for lnk in raw_links if lnk in note_names]
    dropped = set(raw_links) - set(valid_links)
    if dropped:
        logger.debug("Dropped non-existent wikilinks: %s", dropped)
    decision["wikilinks"] = valid_links

    return decision


# ---------------------------------------------------------------------------
# Content transformation
# ---------------------------------------------------------------------------
def insert_wikilinks(content: str, links: list[str]) -> str:
    """Append a Related section with wikilinks at the bottom of the note."""
    if not links:
        return content

    related = "\n\n## Related\n\n"
    related += "\n".join(f"- [[{lnk}]]" for lnk in links)
    return content.rstrip() + related + "\n"


def build_frontmatter(filename: str,
                      tags: list[str] | None = None) -> str:
    """Generate YAML frontmatter for a new note."""
    now = datetime.datetime.now()
    lines = [
        "---",
        f"created: {now.strftime('%Y-%m-%d %H:%M')}",
        f"modified: {now.strftime('%Y-%m-%d %H:%M')}",
        "filed_by: note-sorter",
    ]
    if tags:
        tag_str = ", ".join(tags)
        lines.append(f"tags: {tag_str}")
    lines.append("---")
    return "\n".join(lines)


def strip_existing_frontmatter(content: str) -> tuple[dict | None, str]:
    """If content starts with YAML frontmatter, separate it from the body."""
    if not content.startswith("---"):
        return None, content
    parts = content.split("---", 2)
    if len(parts) < 3:
        return None, content
    # parts[0] is empty, parts[1] is frontmatter, parts[2] is body
    return None, parts[2].lstrip("\n")


# ---------------------------------------------------------------------------
# Filing execution
# ---------------------------------------------------------------------------
def execute_filing(decision: dict, note_path: Path, note_content: str,
                   vault_path: str, filed_dir: str, dry_run: bool,
                   logger: logging.Logger) -> Path | None:
    """Create or append the note in the vault, then move original to Filed."""
    vault = Path(vault_path)
    now = datetime.datetime.now()

    # Prepare content with wikilinks
    _, body = strip_existing_frontmatter(note_content)
    body_with_links = insert_wikilinks(body, decision.get("wikilinks", []))

    if decision["action"] == "new":
        folder = decision["folder"]
        filename = decision["filename"]
        dest = vault / folder / f"{filename}.md"

        # Avoid overwriting existing notes
        if dest.exists():
            counter = 1
            while dest.exists():
                dest = vault / folder / f"{filename} {counter}.md"
                counter += 1
            logger.info("Filename collision, using: %s", dest.name)

        tags = decision.get("suggested_tags", [])
        frontmatter = build_frontmatter(filename, tags if tags else None)
        full_content = frontmatter + "\n\n" + body_with_links

        if dry_run:
            logger.info("[DRY RUN] Would create: %s", dest)
            logger.info("[DRY RUN] Reasoning: %s", decision.get("reasoning", ""))
            return None

        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(full_content)
        logger.info("Created: %s", dest.relative_to(vault))

    elif decision["action"] == "append":
        target_path = vault / decision["target_path"]
        if not target_path.exists():
            logger.error("Append target missing: %s", target_path)
            return None

        append_block = (
            f"\n\n---\n\n"
            f"*Added by Note Sorter on {now.strftime('%Y-%m-%d at %I:%M %p')}*\n\n"
            f"{body_with_links}"
        )

        if dry_run:
            logger.info("[DRY RUN] Would append to: %s", target_path)
            logger.info("[DRY RUN] Reasoning: %s", decision.get("reasoning", ""))
            return None

        with open(target_path, "a") as f:
            f.write(append_block)
        logger.info("Appended to: %s", decision["target_path"])

    # Move original to Filed/
    filed = Path(filed_dir)
    filed.mkdir(parents=True, exist_ok=True)
    timestamp_prefix = now.strftime("%Y%m%d-%H%M%S")
    filed_name = f"{timestamp_prefix}_{note_path.name}"
    filed_dest = filed / filed_name

    if not dry_run:
        shutil.move(str(note_path), str(filed_dest))
        logger.info("Moved original to: Filed/%s", filed_name)

    return filed_dest


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
def main() -> int:
    config = load_config()

    if not config["vault_path"]:
        print("Error: vault_path not set in config.json", file=sys.stderr)
        return 1

    logger = setup_logging(config)

    # Load .env fallback for API key (needed in launchd context)
    load_env_file(config["config_dir"])

    api_key = os.environ.get(config["api_key_env"])
    if not api_key:
        logger.error("API key not found in env var '%s' or .env file",
                      config["api_key_env"])
        return 1

    # Connectivity check
    if not check_connectivity(config["connectivity_timeout_seconds"]):
        logger.info("Offline — skipping this run. Files will be processed next time.")
        return 0

    # Build vault index
    cache_path = Path(config["config_dir"]) / "vault-index.json"
    notes = build_vault_index(
        config["vault_path"], cache_path,
        config["excluded_dirs"], logger,
    )
    vault_index_text = format_index_for_prompt(notes)

    # Load filing preferences
    filing_prompt = load_filing_prompt(config["config_dir"])

    # Get files to process
    files = get_drop_files(
        config["drop_dir"], config["filed_dir"],
        config["file_settle_seconds"],
    )
    if not files:
        logger.debug("No files to process")
        return 0

    logger.info("Processing %d file(s)", len(files))
    client = anthropic.Anthropic(api_key=api_key)

    for note_path in files:
        try:
            note_content = note_path.read_text()
            if not note_content.strip() or note_content.strip() == "#":
                logger.info("Skipping empty file: %s", note_path.name)
                continue

            logger.info("Analyzing: %s", note_path.name)
            decision = analyze_note(
                client, note_content, note_path.name,
                vault_index_text, filing_prompt,
                config["model"], config["max_output_tokens"], logger,
            )
            logger.info("Decision: %s — %s",
                        decision.get("action"), decision.get("reasoning", ""))
            logger.debug("Full decision: %s", json.dumps(decision, indent=2))

            decision = validate_decision(
                decision, config["vault_path"], notes, logger,
            )
            execute_filing(
                decision, note_path, note_content,
                config["vault_path"], config["filed_dir"],
                config["dry_run"], logger,
            )

        except json.JSONDecodeError as e:
            logger.warning("Bad Claude response for %s: %s — skipping",
                           note_path.name, e)
            continue
        except anthropic.APIError as e:
            logger.error("API error processing %s: %s — stopping this run",
                         note_path.name, e)
            break
        except Exception:
            logger.exception("Unexpected error processing %s", note_path.name)
            continue

    logger.info("Run complete")
    return 0


if __name__ == "__main__":
    sys.exit(main())
