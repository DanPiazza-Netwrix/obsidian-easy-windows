{
  "vault_path": "C:\\Users\\YourUsername\\Documents\\My Obsidian Vault",
  "drop_dir": "%USERPROFILE%\\obsidian-drop",
  "filed_dir": "%USERPROFILE%\\obsidian-drop\\Filed",
  "config_dir": "%APPDATA%\\note-sorter",
  "model": "claude-sonnet-4-20250514",
  "max_output_tokens": 1024,
  "api_key_env": "ANTHROPIC_API_KEY",
  "connectivity_timeout_seconds": 5,
  "file_settle_seconds": 5,
  "log_level": "INFO",
  "excluded_dirs": [".trash", ".obsidian", "templates", ".space"],
  "editor": "code",
  "dry_run": true
}
